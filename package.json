{
  "name": "gleito",
  "version": "0.8.0",
  "description": "Lokaler Gleitzeitnachweis als Desktop-App",
  "main": "dist-electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-runner.cjs",
    "build": "tsc -b && vite build && esbuild electron/main.ts electron/preload.ts --bundle --platform=node --format=cjs --outdir=dist-electron --out-extension:.js=.cjs --external:electron",
    "preview": "vite preview --host 127.0.0.1",
    "start": "npm run build && node scripts/run-electron.cjs",
    "test": "vitest run"
  },
  "keywords": [
    "gleitzeit",
    "electron",
    "stadt"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^31.7.7",
    "esbuild": "^0.27.2",
    "jsdom": "^27.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.16",
    "wait-on": "^9.0.3"
  }
}
